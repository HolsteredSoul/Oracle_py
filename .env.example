# Oracle Python Agent — secrets
# Copy this file to .env and fill in your keys.
# This file is .gitignore'd — never commit .env with real secrets.

# OpenRouter API key — used for all LLM calls (Gemini, Claude, Perplexity Sonar)
# Perplexity Sonar (grounded web search for edge candidates) uses the same key.
# Estimated daily cost: ~$2/day (Gemini fast ~$0.01, Perplexity ~$1.40, Claude deep ~$0.50)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional — add when you have them
NEWSDATA_API_KEY=
X_BEARER_TOKEN=

# Football-data.org (free tier — get key at https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=

# API-Basketball / API-Sports (free 100 req/day at https://api-sports.io)
BASKETBALL_API_KEY=

# Betfair credentials (paper trading data and Phase 6 live trading)
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_APP_KEY=
BETFAIR_CERTS_PATH=
